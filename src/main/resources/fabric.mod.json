{
  "schemaVersion": 1,
  "id": "more_enchanting",
  "version": "${version}",
  "name": "More Enchanting",
  "description": "A configurable mod aiming to add useful, original and fun enchantments.",
  "authors": ["pyrod3v"],
  "contact": {},
  "license": "CC-BY-NC-4.0",
  "icon": "assets/more_enchanting/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "gg.pyrod3v.more_enchanting.client.MoreEnchantingDataGenerator"
    ],
    "client": [
      "gg.pyrod3v.more_enchanting.client.MoreEnchantingClient"
    ],
    "main": [
      "gg.pyrod3v.more_enchanting.MoreEnchanting"
    ],
    "cardinal-components": [
      "gg.pyrod3v.more_enchanting.components.MoreEnchantingComponents"
    ]
  },
  "mixins": [
    "more_enchanting.mixins.json",
    {
      "config": "more_enchanting.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": ["26.1", "26.1.1", "26.1.2"]
  },
  "custom": {
    "cardinal-components": [
      "more_enchanting:enchantment_data",
      "more_enchanting:marking"
    ],
    "fzzy_config": [
      "more_enchanting"
    ]
  }
}
